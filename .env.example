# Production uses MySQL/MariaDB for Hostinger compatibility. DATABASE_URL must
# be available during `npm run build` so its prebuild hook can deploy migrations.
# This Hostinger deployment authenticates through 127.0.0.1 rather than localhost.
# URL-encode password characters, for example + as %2B and ! as %21.
DATABASE_URL="mysql://DB_USER:URL_ENCODED_PASSWORD@127.0.0.1:3306/DB_NAME"

AUTH_SECRET="replace-with-a-generated-secret"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production URLs should use https://rahstwistedkitchen.com for all three values.
# Local uploads are intended for development. Production should use durable
# object storage unless this is explicitly enabled as a temporary exception.
ALLOW_LOCAL_UPLOADS_IN_PRODUCTION="false"
BUSINESS_TIME_ZONE="America/New_York"

# Production email delivery requires RESEND_API_KEY plus EMAIL_DRY_RUN=false.
# Keep dry-run and preview files enabled for local QA so real emails are not sent.
RESEND_API_KEY=""
EMAIL_FROM_ADDRESS="Chef Rah's Twisted Kitchen <orders@example.com>"
CONTACT_TO_EMAIL=""

# Legacy optional Stripe placeholders remain only because Stripe env parsing still exists.
# Stripe is not the planned launch payment provider; Square/PayPal integration is future work.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Bootstrap only: register this account normally before promoting it.
OWNER_EMAIL=""
# Temporary secret for POST /api/setup/promote-owner on hosts without console access.
# Generate a long random value (at least 32 characters), remove it after bootstrap,
# and restart/redeploy the app. Leave blank during normal operation.
OWNER_BOOTSTRAP_TOKEN=""

# Temporary secret for POST /api/setup/seed-foundation when production has no console.
# Generate a long random value (at least 32 characters), remove it after seeding,
# and restart/redeploy the app. Leave blank during normal operation.
FOUNDATION_SEED_TOKEN=""

# Legacy single-admin promotion command. Additional admins should be managed by
# the owner from /admin/role-manager after those users register normally.
ADMIN_EMAIL=""
ADMIN_ROLE="ADMIN"

EMAIL_DRY_RUN=true
EMAIL_PREVIEW_FILES=true
