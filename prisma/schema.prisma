// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
  OWNER
}

enum OrderType {
  DELIVERY
  PICKUP
  CATERING
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
  REFUNDED
}

enum MenuItemType {
  PLATE
  A_LA_CARTE
  MEAL_PLAN
  CATERING
  DESSERT
  SIDE
  OTHER
}

enum CateringStatus {
  NEW
  REVIEWING
  QUOTED
  APPROVED
  DEPOSIT_DUE
  DEPOSIT_PAID
  COMPLETED
  CANCELLED
}

enum ApprovalStatus{
  PENDING
  APPROVED
  DENIED
}

enum ServiceRequestType {
  CATERING
  PERSONAL_CHEF
}


model CateringRequest {
  id              String         @id @default(cuid())

  userId          String?
  user            User?          @relation(fields: [userId], references: [id])

  name            String
  email           String
  phone           String?

  eventDate       DateTime?
  eventType       String?
  guestCount      Int?
  location        String?

  requestedMenu   String?
  allergyNotes    String?
  specialRequests String?

  status          CateringStatus @default(NEW)

  estimatedTotal  Decimal?       @db.Decimal(10, 2)
  depositAmount   Decimal?       @db.Decimal(10, 2)
  depositPaidAt   DateTime?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  approvalStatus ApprovalStatus @default(PENDING)
  approvalNote   String?
  approvedAt     DateTime?
  deniedAt       DateTime?
  requestType ServiceRequestType @default(CATERING)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  cateringRequests CateringRequest[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MenuCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  sortOrder Int        @default(0)
  items     MenuItem[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Decimal  @db.Decimal(10, 2)
  available   Boolean  @default(true)
  seasonal    Boolean  @default(false)
  imageUrl    String?
  
  type                        MenuItemType @default(PLATE)
  requiresApproval            Boolean      @default(false)
  customerInstructionsEnabled Boolean      @default(false)

  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])

  orderItems    OrderItem[]

  allergens     MenuItemAllergen[]
  optionGroups  MenuItemOptionGroup[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  archived Boolean @default(false)
}

model Allergen {
  id        String   @id @default(cuid())
  name      String   @unique

  menuItems MenuItemAllergen[]

  createdAt DateTime @default(now())
}

model MenuItemAllergen {
  id          String    @id @default(cuid())

  menuItemId  String
  allergenId  String

  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  allergen    Allergen  @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, allergenId])
}

model MenuItemOptionGroup {
  id          String   @id @default(cuid())

  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  name        String
  required    Boolean  @default(false)
  multiple    Boolean  @default(false)

  choices     MenuItemOptionChoice[]

  createdAt   DateTime @default(now())
}

model MenuItemOptionChoice {
  id              String              @id @default(cuid())

  optionGroupId   String
  optionGroup     MenuItemOptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  dietaryInfo     String?
  imageUrl        String?
  requestOnly     Boolean             @default(false)

  priceDelta      Decimal             @db.Decimal(10, 2) @default(0)

  createdAt       DateTime            @default(now())
}

model Order {
  id                       String      @id @default(cuid())
  userId                   String?
  user                     User?       @relation(fields: [userId], references: [id])

  customerName             String
  customerEmail            String
  customerPhone            String?

  orderType                OrderType
  status                   OrderStatus @default(PENDING)

  requestedDateTime        DateTime?
  allergyNotes             String?
  substitutionPreference   String?

  subtotal                 Decimal     @db.Decimal(10, 2)
  deliveryFee              Decimal     @db.Decimal(10, 2) @default(0)
  lateFee                  Decimal     @db.Decimal(10, 2) @default(0)
  tipAmount                Decimal     @db.Decimal(10, 2) @default(0)
  total                    Decimal     @db.Decimal(10, 2)

  payByDate                DateTime?
  paidAt                   DateTime?
  paymentProvider          String?
  paymentStatus            String?

  items                    OrderItem[]
  statusHistory            OrderStatusHistory[]

  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  approvalStatus ApprovalStatus @default(PENDING)
  approvalNote   String?
  approvedAt     DateTime?
  deniedAt       DateTime?
}

model OrderItem {
  id         String   @id @default(cuid())

  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])

  name       String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  lineTotal  Decimal  @db.Decimal(10, 2)

  notes      String?
}

model OrderStatusHistory {
  id        String      @id @default(cuid())

  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status    OrderStatus
  note      String?

  createdAt DateTime    @default(now())
}

model BusinessSettings {
  id                       String   @id @default(cuid())

  deliveryFee              Decimal  @db.Decimal(10, 2) @default(10)
  lateFee                  Decimal  @db.Decimal(10, 2) @default(10)
  cateringDepositPercent   Int      @default(50)

  orderCutoffDay           Int      @default(4)
  orderCutoffHour          Int      @default(17)
  orderCutoffMinute        Int      @default(0)

  noWeekendOrdering        Boolean  @default(true)
  deliveryArea             String?  @default("Greater Atlanta area")

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}